%% -*- mode: Erlang; fill-column: 80; comment-column: 75; -*-
%% Dependencies ================================================================
{deps, []}.

%% Rebar Plugins ===============================================================
{plugins, [rebar3_hex, {rebar3_ex_doc, "0.2.31"}]}.

%% Compiler Options ============================================================
{erl_opts, [debug_info, warnings_as_errors]}.

%% EUnit =======================================================================
{eunit_opts, [no_tty]}.

{cover_enabled, true}.
{cover_print_enabled, true}.

%% ex_doc ======================================================================
{ex_doc, [
    {main, "README"},
    {extras, ["README.md", "LICENSE"]}
]}.
